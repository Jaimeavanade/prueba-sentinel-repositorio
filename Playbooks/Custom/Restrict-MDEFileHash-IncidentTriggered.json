{
  "resources": [
    {
      "identity": {
        "type": "SystemAssigned"
      },
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "contentVersion": "1.0.0.0",
          "actions": {
            "For_each": {
              "runAfter": {
                "Entities_-_Get_FileHashes": "Succeeded"
              },
              "actions": {
                "Switch": {
                  "type": "Switch",
                  "expression": "@items('For_each')?['Algorithm']",
                  "cases": {
                    "Case_2": {
                      "actions": {
                        "HTTP_2": {
                          "inputs": {
                            "authentication": {
                              "audience": "https://api.securitycenter.windows.com/",
                              "type": "ManagedServiceIdentity"
                            },
                            "uri": "https://api.securitycenter.windows.com/api/indicators",
                            "body": {
                              "action": "AlertAndBlock",
                              "application": "Microsoft Sentinel",
                              "expirationTime": "@{addDays(triggerBody()?['object']?['properties']?['createdTimeUtc'], 90)}",
                              "description": "@{triggerBody()?['object']?['properties']?['incidentNumber']}-@{triggerBody()?['object']?['properties']?['title']}",
                              "title": "@{guid()}",
                              "indicatorValue": "@{items('For_each')?['Value']}",
                              "severity": "@{triggerBody()?['object']?['properties']?['severity']}",
                              "indicatorType": "FileSha256"
                            },
                            "method": "POST"
                          },
                          "type": "Http"
                        }
                      },
                      "case": "SHA256"
                    },
                    "Case": {
                      "actions": {
                        "HTTP": {
                          "inputs": {
                            "authentication": {
                              "audience": "https://api.securitycenter.windows.com/",
                              "type": "ManagedServiceIdentity"
                            },
                            "uri": "https://api.securitycenter.windows.com/api/indicators",
                            "body": {
                              "action": "AlertAndBlock",
                              "application": "Microsoft Sentinel",
                              "expirationTime": "@{addDays(triggerBody()?['object']?['properties']?['createdTimeUtc'], 90)}",
                              "description": "@{triggerBody()?['object']?['properties']?['incidentNumber']}-@{triggerBody()?['object']?['properties']?['title']}",
                              "title": "@{guid()}",
                              "indicatorValue": "@{items('For_each')?['Value']}",
                              "severity": "@{triggerBody()?['object']?['properties']?['severity']}",
                              "indicatorType": "FileSha1"
                            },
                            "method": "POST"
                          },
                          "type": "Http"
                        }
                      },
                      "case": "SHA1"
                    }
                  }
                },
                "Condition": {
                  "runAfter": {
                    "Switch": "Succeeded"
                  },
                  "else": {
                    "actions": {
                      "Add_comment_to_incident_(V3)-2": {
                        "inputs": {
                          "path": "/Incidents/Comment",
                          "body": {
                            "message": "<p class=\"editor-paragraph\">Provided Algorithm was not SHA1 or SHA256 , So no action has been taken</p>",
                            "incidentArmId": "@triggerBody()?['object']?['id']"
                          },
                          "method": "post",
                          "host": {
                            "connection": {
                              "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                            }
                          }
                        },
                        "type": "ApiConnection"
                      }
                    }
                  },
                  "actions": {
                    "Add_comment_to_incident_(V3)-1": {
                      "inputs": {
                        "path": "/Incidents/Comment",
                        "body": {
                          "message": "<p>@{items('For_each')?['Value']} was added to MDE Indicators with action: AlertandBlock via playbook.</p>",
                          "incidentArmId": "@triggerBody()?['object']?['id']"
                        },
                        "method": "post",
                        "host": {
                          "connection": {
                            "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                          }
                        }
                      },
                      "type": "ApiConnection"
                    }
                  },
                  "type": "If",
                  "expression": {
                    "or": [
                      {
                        "equals": [
                          "@item()?['Algorithm']",
                          "SHA1"
                        ]
                      },
                      {
                        "equals": [
                          "@item()?['Algorithm']",
                          "SHA256"
                        ]
                      }
                    ]
                  }
                }
              },
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_FileHashes')?['Filehashes']"
            },
            "Entities_-_Get_FileHashes": {
              "inputs": {
                "path": "/entities/filehash",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "method": "post",
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                }
              },
              "type": "ApiConnection"
            }
          },
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "parameters": {
            "$connections": {
              "type": "Object"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "inputs": {
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation",
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                }
              },
              "type": "ApiConnectionWebhook"
            }
          }
        },
        "provisioningState": "Succeeded",
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]"
              },
              "office365": {
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/office365')]",
                "connectionName": "[variables('Office365ConnectionName')]",
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('Office365ConnectionName'))]"
              }
            }
          }
        },
        "state": "Enabled"
      },
      "name": "[parameters('PlaybookName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('Office365ConnectionName'))]"
      ],
      "apiVersion": "2017-07-01",
      "type": "Microsoft.Logic/workflows",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Restrict-MDEFileHash-IncidentTriggered",
        "hidden-SentinelTemplateVersion": "1.0",
        "hidden-SentinelWorkspaceId": "[resourceId(parameters('WorkspaceResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('WorkspaceName'))]"
      }
    },
    {
      "apiVersion": "2016-06-01",
      "location": "[resourceGroup().location]",
      "kind": "V1",
      "type": "Microsoft.Web/connections",
      "name": "[variables('AzureSentinelConnectionName')]",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "customParameterValues": {},
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "apiVersion": "2016-06-01",
      "location": "[resourceGroup().location]",
      "kind": "V1",
      "type": "Microsoft.Web/connections",
      "name": "[variables('Office365ConnectionName')]",
      "properties": {
        "displayName": "[variables('Office365ConnectionName')]",
        "customParameterValues": {},
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/office365')]"
        }
      }
    }
  ],
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "Office365ConnectionName": "[concat('office365-', parameters('PlaybookName'))]"
  },
  "parameters": {
    "PlaybookName": {
      "defaultValue": "Test-Restrict-MDEFileHash-IncidentTriggered",
      "type": "string"
    },
    "WorkspaceName": {
      "defaultValue": "clientejvs-sentinelwk",
      "type": "string",
      "metadata": {
        "description": "Nombre del Log Analytics Workspace donde está habilitado Microsoft Sentinel (solo para el tag hidden-SentinelWorkspaceId)."
      }
    },
    "WorkspaceResourceGroup": {
      "defaultValue": "clientejvs-sentinelrg",
      "type": "string",
      "metadata": {
        "description": "RG del Log Analytics Workspace donde está habilitado Microsoft Sentinel (solo para el tag hidden-SentinelWorkspaceId)."
      }
    }
  },
  "metadata": {
    "description": "",
    "author": {
      "name": ""
    },
    "lastUpdateTime": "",
    "prerequisites": "",
    "support": {
      "armtemplate": "Generated from https://github.com/Azure/Azure-Sentinel/tree/master/Tools/Playbook-ARM-Template-Generator",
      "tier": "community"
    },
    "entities": null,
    "postDeployment": null,
    "title": "",
    "tags": null,
    "prerequisitesDeployTemplateFile": ""
  },
  "contentVersion": "1.0.0.0",
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#"
}
