{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/c408b5c0-7b6d-4356-b446-7ccbbe696bf1')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/c408b5c0-7b6d-4356-b446-7ccbbe696bf1')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "AUTO DISABLED CNC0014 - Transferencia de datos inusual desde una VM a ubicaciones externas",
                "description": "The alert rule was disabled due to too many consecutive failures. Reason: This rule was automatically disabled due to insufficient permissions. The rule requires permissions which are different from those held by the user who created the rule at the time of rule creation. This often happens due to changes in functions used or references to external data. Please edit and re-save the rule with a user that can execute the query in it. For troubleshooting guidance, see: https://aka.ms/AnalyticsAutoDisabledRules Este caso de uso tiene como objetivo detectar posibles transferencias de datos anómalas o potenciales intentos de exfiltración de información desde máquinas virtuales (VMs) hacia ubicaciones externas.\n\nLa detección se basa en alertas de seguridad generadas por los servicios de protección de Microsoft que identifican patrones sospechosos de tráfico saliente, como volúmenes de datos inusualmente altos y destinos poco habituales.\n\n\nLa búsqueda se ejecutará cada 5 min. teniendo en cuenta la última hora.",
                "severity": "High",
                "enabled": false,
                "query": "SecurityAlert\n| where TimeGenerated > ago(7d)\n| where AlertName has_any (\n    \"Unusual outbound traffic\",\n    \"Potential data exfiltration\",\n    \"Suspicious data transfer\",\n    \"Large volume of outbound data\",\n    \"Exfiltration to external location\",\n    \"Data transfer to rare country\",\n    \"Possible command and control (C2) communication\"\n)\nor Description has_any (\"data exfiltration\", \"unusual outbound\", \"external transfer\", \"exfil\", \"rare location\")\n| project TimeGenerated, AlertName, AlertSeverity ,Description, CompromisedEntity, ProductName, ProviderName\n| order by TimeGenerated desc\n",
                "queryFrequency": "PT5M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "CommandAndControl"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "Fecha",
                            "NombreAlerta",
                            "Severidad",
                            "Descripcion",
                            "Indicador",
                            "NombreProducto",
                            "NombreProveedor"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDynamicProperties": []
                },
                "customDetails": {
                    "Fecha": "TimeGenerated",
                    "NombreAlerta": "AlertName",
                    "Severidad": "AlertSeverity",
                    "Descripcion": "Description",
                    "Indicador": "CompromisedEntity",
                    "NombreProducto": "ProductName",
                    "NombreProveedor": "ProviderName"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "AlertName"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "AlertSeverity"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "Description"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "CompromisedEntity"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "ProductName"
                            },
                            {
                                "identifier": "Name",
                                "columnName": "ProviderName"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}