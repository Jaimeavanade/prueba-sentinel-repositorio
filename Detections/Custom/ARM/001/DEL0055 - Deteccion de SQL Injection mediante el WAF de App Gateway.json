{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/fa8375b2-757f-4d40-ba0b-47aff854c59b')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/fa8375b2-757f-4d40-ba0b-47aff854c59b')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "DEL0055 - Deteccion de SQL Injection mediante el WAF de App Gateway",
                "description": "Identifica una coincidencia para un ataque de inyección SQL en los registros WAF de App Gateway. El valor del umbral en la consulta se puede cambiar según los requisitos de su infraestructura.\nReferencias: https://owasp.org/Top10/A03_2021-Injection/",
                "severity": "High",
                "enabled": true,
                "query": "let Threshold = 5;  \nAzureDiagnostics\n| where Category == \"ApplicationGatewayFirewallLog\"\n| where action_s == \"Matched\"\n| where Message has \"SQL Injection\"\n| where clientIp_s !contains \"217.\"\n| project\n    transactionId_g,\n    hostname_s,\n    requestUri_s,\n    TimeGenerated,\n    clientIp_s,\n    Message,\n    details_message_s,\n    details_data_s\n| join kind = inner(\n    AzureDiagnostics\n    | where Category == \"ApplicationGatewayFirewallLog\"\n    | where action_s == \"Blocked\")\n    on transactionId_g\n| extend Uri = strcat(hostname_s, requestUri_s)\n| summarize\n    Fecha = min(TimeGenerated),\n    EndTime = max(TimeGenerated),\n    TransactionID = make_set(transactionId_g, 100),\n    Message = make_set(Message, 100),\n    Detail_Message = make_set(details_message_s, 100),\n    Detail_Data = make_set(details_data_s, 100),\n    Total_TransactionId = dcount(transactionId_g)\n    by clientIp_s, Uri, action_s\n| where Total_TransactionId >= Threshold\n\n",
                "queryFrequency": "PT5H",
                "queryPeriod": "P1D",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT1H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "DefenseEvasion",
                    "Execution",
                    "InitialAccess",
                    "PrivilegeEscalation"
                ],
                "techniques": [
                    "T1211",
                    "T1059",
                    "T1190",
                    "T0890"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": "bdb2cd63-99f2-472e-b1b9-acba473b6744",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "ClientIP"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "Fecha": "Fecha",
                    "ClientIP": "clientIp_s",
                    "PathURL": "Uri",
                    "Accion": "action_s",
                    "Mensaje": "Message"
                },
                "entityMappings": [
                    {
                        "entityType": "URL",
                        "fieldMappings": [
                            {
                                "identifier": "Url",
                                "columnName": "Uri"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "clientIp_s"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": "1.0.0"
            }
        }
    ]
}