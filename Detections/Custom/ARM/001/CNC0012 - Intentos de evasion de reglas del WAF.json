{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/5a80964f-b040-462d-be37-cb244bc71db8')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/5a80964f-b040-462d-be37-cb244bc71db8')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "CNC0012 - Intentos de evasion de reglas del WAF",
                "description": "Identificar ataques que intentan eludir las reglas de seguridad del WAF mediante codificación  de caracteres o manipulación de peticiones.",
                "severity": "Medium",
                "enabled": true,
                "query": "let LookbackHours = 1;\nlet MinRequests = 20;          // Ajusta según ruido\nAzureDiagnostics\n| where TimeGenerated >= ago(LookbackHours * 1h)\n| where Category == \"ApplicationGatewayAccessLog\"\n| where httpStatus_d in (400, 403)\n// Excluir health probes de Azure / tráfico conocido\n| where userAgent_s !startswith \"ApplicationGatewayHealthProbe\"\n| where userAgent_s !startswith \"AlwaysOn\"\n// Excluir IPs internas \n| where not(ipv4_is_private(clientIP_s))\n| summarize\n    TotalRequests   = count(),\n    StatusCodes     = make_set(httpStatus_d, 5),           // hasta 5 códigos distintos\n    SampleUrl       = any(originalRequestUriWithArgs_s),   // una URL de ejemplo\n    SampleUserAgent = any(userAgent_s),                    // un UA de ejemplo\n    SamplePorts     = make_set(clientPort_d, 5),           // hasta 5 puertos\n    FirstSeen       = min(TimeGenerated),\n    LastSeen        = max(TimeGenerated)\n    by\n    AttackingIP  = clientIP_s,\n    originalHost_s,\n    bin(TimeGenerated, 1h)\n| where TotalRequests >= MinRequests\n| project\n    Fecha = TimeGenerated,\n    AttackingIP,\n    OriginalHost = originalHost_s, // no lo veremos como agrupamos las peticiones por IPs y el host no es el mismo.\n    TotalRequests,\n    StatusCodes,\n    SamplePorts,\n    SampleUrl,\n    SampleUserAgent,\n    FirstSeen,\n    LastSeen\n| order by TotalRequests desc\n\n",
                "queryFrequency": "PT5H",
                "queryPeriod": "P1D",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 1,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess",
                    "DefenseEvasion",
                    "Persistence"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP",
                            "URL",
                            "Host",
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "Fecha": "Fecha",
                    "DireccionIP": "AttackingIP",
                    "OriginalHost": "OriginalHost",
                    "httpMethod": "StatusCodes",
                    "PathURL": "SampleUrl"
                },
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "AttackingIP"
                            }
                        ]
                    },
                    {
                        "entityType": "URL",
                        "fieldMappings": [
                            {
                                "identifier": "Url",
                                "columnName": "SampleUrl"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "OriginalHost"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "ObjectGuid",
                                "columnName": "StatusCodes"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}