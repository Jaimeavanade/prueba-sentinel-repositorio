{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/6f6ac09b-e230-4a3c-a996-8081fc9f8c6f')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/6f6ac09b-e230-4a3c-a996-8081fc9f8c6f')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "DEL0065 - Uso Anomalo de Azure Bastion por Usuario Autorizado",
                "description": "Este caso de uso tiene como objetivo detectar patrones anómalos de acceso a máquinas virtuales mediante Azure Bastion, incluso cuando el acceso se realiza por usuarios legítimos y autorizados.\n\nAzure Bastion proporciona acceso administrativo seguro a máquinas virtuales sin exponerlas a Internet. No obstante, el abuso de credenciales válidas, cuentas comprometidas o el uso indebido por parte de usuarios internos puede derivar en accesos no autorizados, movimiento lateral o actividades maliciosas dentro del entorno cloud.",
                "severity": "Medium",
                "enabled": false,
                "query": "let TimeWindow = 1h; //Agrupa la actividad por ventanas de 1 hora para detectar picos anómalos.\nlet Threshold = 63; //Define el número mínimo de conexiones en una hora que se considera sospechoso.\nMicrosoftAzureBastionAuditLogs\n| where TimeGenerated > ago(7d)\n| summarize\n    Connections=count(), //Número total de conexiones Bastion del usuario en esa hora.\n    DistinctVMs=dcount(TargetResourceId), //Cuántas máquinas virtuales distintas ha accedido el usuario en la misma ventana.\n    FirstSeen=min(TimeGenerated),\n    LastSeen=max(TimeGenerated)\n    by UserName, UserEmail,ClientIpAddress,bin(TimeGenerated, TimeWindow)\n| where Connections >= Threshold or DistinctVMs >= 5 //Muchas conexiones en poco tiempo or Acceso a múltiples VMs\n| project\n    TimeGenerated,\n    UserName,\n    UserEmail, \n    IPAddress = ClientIpAddress,\n    Connections,\n    DistinctVMs,\n    FirstSeen,\n    LastSeen\n| order by Connections desc\n\n",
                "queryFrequency": "PT5M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "PrivilegeEscalation",
                    "InitialAccess",
                    "LateralMovement"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account",
                            "IP"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "FechaInicio",
                            "NombreUsuario",
                            "CorreoUsuario",
                            "Conexiones",
                            "MVirtualDistintas",
                            "IPAddress"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "FechaInicio": "FirstSeen",
                    "UltimaVezVisto": "LastSeen",
                    "NombreUsuario": "UserName",
                    "CorreoUsuario": "UserEmail",
                    "Conexiones": "Connections",
                    "MVirtualDistintas": "DistinctVMs",
                    "IPAddress": "IPAddress"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "UserName"
                            },
                            {
                                "identifier": "Name",
                                "columnName": "UserEmail"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "ObjectGuid",
                                "columnName": "Connections"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "PUID",
                                "columnName": "DistinctVMs"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IPAddress"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}