{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/410f6a71-a36b-4da2-9438-a093368c4e33')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/410f6a71-a36b-4da2-9438-a093368c4e33')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "COM0060 - Fallos de Autenticacion Multifactor en 1 hora",
                "description": "Comprobación de fallos MFA desde IP's externas > 3 por hora",
                "severity": "Medium",
                "enabled": true,
                "query": "// Signin Locations \n// Failed and successful sig ins by source location. \nSigninLogs\n//| summarize Successful=countif(ResultType==0), Failed=countif(ResultType!=0) by Location\n| where NetworkLocationDetails !contains \"network\"\n| where Status contains \"failure\"\n| where ResultDescription contains \"required\"\n| where ConditionalAccessStatus contains \"failure\"\n| summarize loginfailures =count() by UserDisplayName, IPAddress\n",
                "queryFrequency": "PT1H",
                "queryPeriod": "PT5H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "CredentialAccess"
                ],
                "techniques": [
                    "T1621"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP",
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "IPAddress",
                            "Usuario",
                            "IntentosFallidos"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDynamicProperties": []
                },
                "customDetails": {
                    "Usuario": "UserDisplayName",
                    "IPAddress": "IPAddress",
                    "IntentosFallidos": "loginfailures"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "UserDisplayName"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "ObjectGuid",
                                "columnName": "loginfailures"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IPAddress"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}