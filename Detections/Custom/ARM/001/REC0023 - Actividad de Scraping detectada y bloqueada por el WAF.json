{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/3f7e2507-65bd-4491-8249-461e50268ec8')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/3f7e2507-65bd-4491-8249-461e50268ec8')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "AUTO DISABLED REC0023 - Actividad de Scraping detectada y bloqueada por el WAF",
                "description": "The alert rule was disabled due to too many consecutive failures. Reason: This rule was automatically disabled due to insufficient permissions. The rule requires permissions which are different from those held by the user who created the rule at the time of rule creation. This often happens due to changes in functions used or references to external data. Please edit and re-save the rule with a user that can execute the query in it. For troubleshooting guidance, see: https://aka.ms/AnalyticsAutoDisabledRules Bloquear tráfico de bots que intentan extraer datos, consumir recursos o explotar vulnerabilidades.",
                "severity": "Low",
                "enabled": false,
                "query": "AzureDiagnostics\r\n| where Category == \"ApplicationGatewayAccessLog\"\r\n| where httpStatus_d == 403 or httpStatus_d == 429 // Acceso bloqueado o demasiadas solicitudes // añadir el 404 también\r\n| where userAgent_s !in (\"Bingbot\", \"Googlebot\", \"Facebookbot\") // Excluir bots legítimos \r\n| where userAgent_s contains \"Bot\"\r\n| extend AttackingIP = clientIP_s, Port = clientPort_d, httpMethod = httpMethod_s, httpVersion=httpVersion_s, URL = originalRequestUriWithArgs_s, UserAgent = userAgent_s, InstaceId = instanceId_s, RuleName = ruleName_s, RequestQuery = requestQuery_s, ErrorInfo = error_info_s, OriginalHost = originalHost_s\r\n| summarize RequestCount = count() by AttackingIP, Port, httpMethod,httpVersion, URL, UserAgent,RuleName,RequestQuery,ErrorInfo, OriginalHost, bin(TimeGenerated, 10m)\r\n| where RequestCount > 50  // Más de 50 solicitudes en 10 minutos\r\n| order by RequestCount desc",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 50,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Reconnaissance",
                    "Discovery"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP",
                            "URL",
                            "Account",
                            "Host"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "AttackingIP",
                            "Port",
                            "httpMethod",
                            "httpVersion",
                            "URL",
                            "UserAgent",
                            "RuleName",
                            "RequestQuery",
                            "ErrorInfo",
                            "OriginalHost"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDynamicProperties": []
                },
                "customDetails": {
                    "AttackingIP": "AttackingIP",
                    "Port": "Port",
                    "httpMethod": "httpMethod",
                    "httpVersion": "httpVersion",
                    "URL": "URL",
                    "UserAgent": "UserAgent",
                    "RuleName": "RuleName",
                    "RequestQuery": "RequestQuery",
                    "ErrorInfo": "ErrorInfo",
                    "OriginalHost": "OriginalHost"
                },
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "AttackingIP"
                            }
                        ]
                    },
                    {
                        "entityType": "URL",
                        "fieldMappings": [
                            {
                                "identifier": "Url",
                                "columnName": "URL"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "UserAgent"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "RequestQuery"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "HostName",
                                "columnName": "OriginalHost"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "ObjectGuid",
                                "columnName": "RequestCount"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}