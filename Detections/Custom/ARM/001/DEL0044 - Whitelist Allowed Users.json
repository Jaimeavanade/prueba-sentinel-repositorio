{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a13414aa-ddff-4eec-a92d-533a06c6d915')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a13414aa-ddff-4eec-a92d-533a06c6d915')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "DEL0044 - Whitelist Allowed Users",
                "description": "Esta detección señala cuando un usuario de la lista de accesos permitidos se conecta desde un ordenador que no está permitido/registrado.",
                "severity": "High",
                "enabled": false,
                "query": "let usuarios_permitidos = datatable(UserPrincipalName: string, deviceId: string)\n[\n    \"daniel.sanchez-molina@pidpia.onmicrosoft.com\", \"344fa4bf-8822-4dd7-9610-eca3fbfe63df\", \n    \"sergio.bernal@pidpia.onmicrosoft.com\", \"a523c310-9168-4078-b913-ced80dafdec2\"\n  // \"AÑADIR LOS USUARIOS PERMITIDOS QUE FALTAN\", \"AÑADIR EL DEVICEID\",\n];\nSigninLogs\n//| where TimeGenerated >= ago(5m)  // Ajusta el rango de tiempo según tu necesidad\n| where UserPrincipalName in (usuarios_permitidos\n| project UserPrincipalName) // Filtrar usuarios permitidos\n| extend ParsedDeviceDetail = parse_json(DeviceDetail) // Convertir DeviceDetail a JSON\n| extend ExtractedDeviceId = tostring(ParsedDeviceDetail.deviceId) // Extraer el DeviceId\n| join kind=leftouter usuarios_permitidos on UserPrincipalName // Relacionar con la tabla permitidos\n| extend CoincideDeviceId = iff(ExtractedDeviceId == deviceId, \"Sí\", \"No\") // Comparar DeviceId\n| where CoincideDeviceId == \"No\" or isnull(ExtractedDeviceId) // Si no coincide o está vacío\n| project TimeGenerated, UserPrincipalName, ExtractedDeviceId, deviceId, IPAddress, AuthenticationDetails, DeviceDetail\n",
                "queryFrequency": "PT5M",
                "queryPeriod": "PT30M",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess",
                    "CredentialAccess"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "TimeGenerated": "TimeGenerated",
                    "UserPrincipalName": "UserPrincipalName",
                    "ExtractedDeviceId": "ExtractedDeviceId",
                    "deviceId": "deviceId",
                    "IPAddress": "IPAddress",
                    "Authentication": "AuthenticationDetails",
                    "DeviceDetail": "DeviceDetail"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "UserPrincipalName"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "ExtractedDeviceId"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IPAddress"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}