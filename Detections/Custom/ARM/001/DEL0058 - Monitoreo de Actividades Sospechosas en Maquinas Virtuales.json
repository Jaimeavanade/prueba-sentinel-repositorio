{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/2578b0e6-8281-4670-985a-eeb17b8184c6')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/2578b0e6-8281-4670-985a-eeb17b8184c6')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "DEL0058 - Monitoreo de Actividades Sospechosas en Maquinas Virtuales",
                "description": "Este caso de uso tiene como objetivo detectar actividades potencialmente sospechosas en máquinas virtuales (VMs) accedidas mediante Microsoft Azure Bastion, enfocándose en patrones de uso anómalos relacionados con el origen de la conexión y el horario de acceso.\n\nLa detección se centra en accesos realizados desde direcciones IP no corporativas y fuera del horario laboral, lo que puede indicar uso indebido de credenciales, accesos no autorizados o actividades administrativas no planificadas.\n\nLa búsqueda se ejecutará cada 5 minutos teniendo en cuenta la última hora.",
                "severity": "Medium",
                "enabled": false,
                "query": "MicrosoftAzureBastionAuditLogs\n//| where TimeGenerated > ago(5m)\n| extend User = coalesce(UserEmail, UserName)\n| extend Hour = datetime_part(\"hour\", TimeGenerated)\n| where OperationName has \"Failed\" or isnull(SessionEndTime) or Duration > 3600 or Hour < 8 or Hour > 18 // La sesión no tiene registrada una hora de finalización, dura más de 1 hora o se encuentra fuera del horario laboral.\n| where ClientIpAddress !startswith \"10.\" and ClientIpAddress !startswith \"192.168\" // Para conexiones desde direcciones IP no corporativas\n//| where datetime_part(\"hour\", TimeGenerated) < 8 or datetime_part(\"hour\", TimeGenerated) > 19 // Para conexiones fuera del horario laboral. \n| extend User = coalesce(UserEmail, UserName)\n| project\n    TimeGenerated,\n    OperationName,\n    User,\n    ClientIpAddress,\n    Protocol,\n    TargetVMIPAddress,\n    Duration,\n    Message\n| order by TimeGenerated desc\n",
                "queryFrequency": "PT5H",
                "queryPeriod": "PT5H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess",
                    "CredentialAccess"
                ],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account",
                            "IP",
                            "Host"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": [
                            "Fecha",
                            "ActividadDetectada",
                            "Usuario",
                            "ClientIpAddress",
                            "Protocol",
                            "IPAddress_VM",
                            "Duracion",
                            "Conexion"
                        ]
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "Fecha": "TimeGenerated",
                    "ActividadDetectada": "OperationName",
                    "Usuario": "User",
                    "ClientIpAddress": "ClientIpAddress",
                    "Protocol": "Protocol",
                    "IPAddress_VM": "TargetVMIPAddress",
                    "Duracion": "Duration",
                    "Conexion": "Message"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "OperationName"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "User"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "ClientIpAddress"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "HostName",
                                "columnName": "Protocol"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "TargetVMIPAddress"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Sid",
                                "columnName": "Duration"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "Message"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}