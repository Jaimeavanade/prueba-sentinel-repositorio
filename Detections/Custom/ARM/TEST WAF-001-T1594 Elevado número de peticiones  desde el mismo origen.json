{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "resources": [
    {
      "type": "Microsoft.SecurityInsights/alertRules",
      "kind": "Scheduled",
      "name": "[concat(parameters('workspaceName'),'/',System.Collections.Hashtable.id)]",
      "properties": {
        "description": "",
        "triggerOperator": "GreaterThan",
        "enabled": true,
        "queryFrequency": "PT5H",
        "queryPeriod": "PT5H",
        "query": "let Umbral = 1000;\nAzureDiagnostics\n| where httpMethod_s == \"GET\"\n| summarize Peticiones = count() by socketIp_s, requestUri_s\n| where Peticiones > Umbral",
        "severity": "Medium",
        "tactics": [],
        "techniques": [],
        "displayName": "[TEST] WAF-001-T1594 Elevado número de peticiones  desde el mismo origen",
        "triggerThreshold": 0
      },
      "apiVersion": "2022-12-01-preview"
    }
  ],
  "parameters": {
    "workspaceName": {
      "type": "string"
    }
  },
  "contentVersion": "1.0.0.0"
}
