{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/7cd23750-72b5-42aa-9ba5-9caee4c12edd')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/7cd23750-72b5-42aa-9ba5-9caee4c12edd')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[GEN][MIN] AS-SNTL-040 Detectado secret expirado en integración XSOAR",
                "description": "Busca secret expirado en el Service Principal de la integración usada por XSOAR, no genera incidente en la plataforma de TTECH, ya que la integración con nuestro entorno usa esta plataforma.",
                "severity": "High",
                "enabled": true,
                "query": "AADServicePrincipalSignInLogs\r\n| where TimeGenerated > ago(1d)\r\n//Modificar para CDU personalizados, donde el nombre no se puede modificar\r\n| where ServicePrincipalName == \"app-pid-pre-spn-xsoar-001\"\r\n| summarize\r\n    ['All Error Codes']=make_set(ResultType),\r\n    ['Successful IP Addresses']=make_set_if(IPAddress, ResultType == 0),\r\n    ['Failed IP Addresses']=make_set_if(IPAddress, ResultType == \"7000222\")\r\n    by ServicePrincipalId, ServicePrincipalName\r\n| where ['All Error Codes'] has_all (\"0\", \"7000222\")\r\n| project TargetAppId = ServicePrincipalId, TargetAppName = ServicePrincipalName, EventResult = ['All Error Codes'], EventFailedIp = ['Failed IP Addresses'], EventSuccessIp = ['Successful IP Addresses']",
                "queryFrequency": "PT1H",
                "queryPeriod": "P1D",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Persistence"
                ],
                "techniques": [
                    "T1098"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": "7cd23750-72b5-42aa-9ba5-9caee4c12edd",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": true,
                        "lookbackDuration": "P1D",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "AzureResource"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "AS-SNTL-040 Detectado secret expirado en integración XSOAR en {{TargetAppName}}",
                    "alertDescriptionFormat": "Se ha detectado secret expirado en {{TargetAppName}}. Fallos desde \"{{EventFailedIp}}\".",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "AzureResource",
                        "fieldMappings": [
                            {
                                "identifier": "ResourceId",
                                "columnName": "TargetAppId"
                            }
                        ]
                    },
                    {
                        "entityType": "CloudApplication",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "TargetAppName"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": "1.0.1"
            }
        }
    ]
}