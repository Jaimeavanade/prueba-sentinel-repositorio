{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/91e8e46f-560d-4084-b8af-368e15fc55dc')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/91e8e46f-560d-4084-b8af-368e15fc55dc')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[GEN][MIN] AS-SNTL-004 Superada la ingesta de GB diarios",
                "description": "Detectado ingesta de más de un umbral GB en las ultimas 24h, esto debe indicarse en watchlist: watchlist__AS_STNL_004_overquota, indicando un valor inferior al dailycap configurado en Log Analytics.",
                "severity": "High",
                "enabled": false,
                "query": "let watchlist_AS_STNL_004_overquota = toscalar(_GetWatchlist(\"watchlist__AS_STNL_004_overquota\") | project SearchKey);\nUsage\n| where TimeGenerated > ago(1d)\n| where IsBillable == true\n| summarize TotalVolumeGB = sum(Quantity) / 1024\n| where TotalVolumeGB > toint(watchlist_AS_STNL_004_overquota)\n| project-rename SrcBytesGB = TotalVolumeGB\n",
                "queryFrequency": "P1D",
                "queryPeriod": "P1D",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": "91e8e46f-560d-4084-b8af-368e15fc55dc",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": false,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "AS-SNTL-004 Superada la ingesta de {{SrcBytesGB}}  GB diarios",
                    "alertDescriptionFormat": "Se sobrepasa el límite de {{SrcBytesGB}} configurados.",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": null,
                "sentinelEntitiesMappings": null,
                "templateVersion": "1.1.0"
            }
        }
    ]
}