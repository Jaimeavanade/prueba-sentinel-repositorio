{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/d38c1688-3759-44fd-86dc-3ac876345d00')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/d38c1688-3759-44fd-86dc-3ac876345d00')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[SEGITTUR] DS-WAF-002-T1083 Detectados multiples errores 500",
                "description": "Deteccion multiples errores 500,502,503,504",
                "severity": "Medium",
                "enabled": true,
                "query": "let threshold = 30; \r\nlet timeRange = 10m;\r\nAzureDiagnostics\r\n| where ResourceType in (\"FRONTDOORS\", \"PROFILES\")\r\n| where httpStatusCode_d in (500,502,503,504)\r\n| where TimeGenerated > ago(timeRange)\r\n| summarize Message=make_set(Message),startTime=min(TimeGenerated),endTime=max(TimeGenerated),EventCount = count() by httpStatusCode_d,clientIp_s,OperationName,probeUrl_s \r\n| where EventCount>=threshold",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 10,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "URL"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "AlertPerResult"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[SEGITTUR] DS-WAF-002-T1083 Detectados multiples errores 500 {{clientIp_s}}  {{probeUrl_s}} ",
                    "alertDescriptionFormat": "[SEGITTUR] DS-WAF-002-T1083 Detectados multiples errores 500 {{clientIp_s}}   {{probeUrl_s}} ",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "URL",
                        "fieldMappings": [
                            {
                                "identifier": "Url",
                                "columnName": "probeUrl_s"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}