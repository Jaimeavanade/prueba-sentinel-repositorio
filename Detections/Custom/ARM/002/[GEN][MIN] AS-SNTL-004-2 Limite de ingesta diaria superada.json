{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/8c2e46ec-c4bb-4672-8721-f2f292298222')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/8c2e46ec-c4bb-4672-8721-f2f292298222')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[GEN][MIN] AS-SNTL-004-2 Limite de ingesta diaria superada",
                "description": "Se detecta que el límite diario ha sido sobrepasado por la alerta configurada en LogAnalytics",
                "severity": "Medium",
                "enabled": false,
                "query": "Operation\r\n| where Detail has 'OverQuota'\r\n| project TimeGenerated, Operation = OperationStatus, EventType = Detail, EventSubType = OperationKey, Object = OperationCategory",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT10M",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": "8c2e46ec-c4bb-4672-8721-f2f292298222",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "P1D",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "AS-SNTL-004-2 Limite de ingesta diaria superada",
                    "alertDescriptionFormat": "Se detecta que el límite de ingesta configurado en el daily cap ha sido superado.",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": null,
                "sentinelEntitiesMappings": null,
                "templateVersion": "1.1.0"
            }
        }
    ]
}