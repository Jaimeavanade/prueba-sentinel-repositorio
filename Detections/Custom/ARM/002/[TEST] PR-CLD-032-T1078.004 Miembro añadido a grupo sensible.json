{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/c46366c5-897a-41a5-b462-49ff474f0897')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/c46366c5-897a-41a5-b462-49ff474f0897')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[TEST] PR-CLD-032-T1078.004 Miembro añadido a grupo sensible",
                "description": "Detecta miembro añadido a un grupo sensible definido en watchlist.",
                "severity": "Low",
                "enabled": true,
                "query": "let watchlist_PR_CLD_031_032_Group = (_GetWatchlist(\"watchlist_PR_CLD_031_032_Group\") | project SearchKey);\r\nAuditLogs\r\n| where OperationName == \"Add member to group\"\r\n| extend ActorUsername = tostring(InitiatedBy.user.userPrincipalName)\r\n| where isnotempty(ActorUsername)\r\n| extend GroupName = tostring((TargetResources[0].modifiedProperties)[1].newValue)\r\n| where GroupName in~ (watchlist_PR_CLD_031_032_Group) // Grupos sensibles, modificar whatchlist\r\n| extend AddUser = tostring(TargetResources[0].userPrincipalName)\r\n| extend AddUserId = tostring((TargetResources[0].modifiedProperties)[0].newValue)\r\n| extend ActorUsername = tostring(InitiatedBy.user.userPrincipalName)\r\n| where isnotempty(ActorUsername)\r\n| project TimeGenerated, TargetUsername = AddUser, TargetUserScopeId = AddUserId, GroupName, ActorUsername",
                "queryFrequency": "PT1H",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Persistence"
                ],
                "techniques": [
                    "T1078"
                ],
                "subTechniques": [
                    "T1078.004"
                ],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "P1D",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[TEST]PR-CLD-032-T1078.004 Miembro añadido a grupo sensible por {{ActorUsername}}",
                    "alertDescriptionFormat": "Se detecta {{TargetUsername}} añadido por {{ActorUsername}} en el grupo {{GroupName}}.",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "ActorUsername"
                            }
                        ]
                    },
                    {
                        "entityType": "SecurityGroup",
                        "fieldMappings": [
                            {
                                "identifier": "DistinguishedName",
                                "columnName": "GroupName"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}