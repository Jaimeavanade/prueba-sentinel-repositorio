{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/3416efba-0271-4225-87de-3a1c5bb559d9')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/3416efba-0271-4225-87de-3a1c5bb559d9')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[SEGITTUR] CC-FW-033-T1071 Conexión bloqueada saliente contra IP maliciosa",
                "description": "CC-FW-033-T1071 Conexión bloqueada saliente contra IP maliciosa",
                "severity": "Low",
                "enabled": true,
                "query": "AzureDiagnostics\n| where ResourceType == \"AZUREFIREWALLS\"\n| where Category == \"AZFWThreatIntel\"\n| where Action_s != \"Alert\"\n| summarize startTime=min(TimeGenerated), endTime=max(TimeGenerated), EventCount = count() by SourceIP, DestinationIp_s, ThreatDescription_s, Action_s\n\n",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP"
                        ],
                        "groupByAlertDetails": [
                            "DisplayName"
                        ],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "AlertPerResult"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[SEGITTUR] CC-FW-033-T1071 Conexión bloqueada saliente contra IP maliciosa {{DestinationIp_s}} ",
                    "alertDescriptionFormat": "[SEGITTUR] CC-FW-033-T1071 Conexión bloqueada saliente contra IP maliciosa hacia {{DestinationIp_s}}  desde {{SourceIP}} ",
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "SourceIP"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "DestinationIp_s"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}