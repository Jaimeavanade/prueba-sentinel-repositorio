{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/85e341d8-0d47-4646-b503-d398573a72ff')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/85e341d8-0d47-4646-b503-d398573a72ff')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[TEST] SigIn in Risk in AAD",
                "description": "Monitorización de los inicios de sesión en riesgo en AAD.",
                "severity": "Informational",
                "enabled": true,
                "query": "AADUserRiskEvents\r\n| where OperationName == \"User Risk Detection\"\r\n| where RiskLevel != \"low\"\r\n| where Activity == \"signin\"\r\n| where RiskState == \"atRisk\"\r\n| project TimeGenerated, UserDisplayName, UserPrincipalName, RiskState, Activity, IpAddress, Location, DetectionTimingType, RiskEventType ",
                "queryFrequency": "PT1H",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "InitialAccess"
                ],
                "techniques": [
                    "T1133"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "P1D",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[TEST] SigIn in Risk in AAD",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": null,
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}