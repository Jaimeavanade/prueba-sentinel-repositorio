{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/3412992c-15cf-46e1-9f91-529219032215')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/3412992c-15cf-46e1-9f91-529219032215')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[TEST][SEGITTUR] DS-WAF-005 Trafico denegado",
                "description": "Detección de trafico denegado en waf por reglas",
                "severity": "Low",
                "enabled": false,
                "query": "let timeRange = 10m;\r\nlet watchlist_DS_WAF_005 = _GetWatchlist(\"watchlist_DS_WAF_005\");\r\nAzureDiagnostics\r\n| where TimeGenerated > ago(timeRange)\r\n| where ruleName_s !in (watchlist_DS_WAF_005)\r\n| where ResourceType in (\"FRONTDOORS\", \"PROFILES\")\r\n| where action_s == \"Block\"\r\n| where isnotempty( clientIP_s)\r\n|summarize by clientIP_s,requestUri_s, ruleName_s",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 20,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP",
                            "Process"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[TEST][SEGITTUR] DS-WAF-005 Trafico denegado {{ruleName_s}} ",
                    "alertDescriptionFormat": "[TEST]DS-WAF-005 Trafico denegado {{ruleName_s}}   desde IP {{clientIP_s}} ",
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "clientIP_s"
                            }
                        ]
                    },
                    {
                        "entityType": "URL",
                        "fieldMappings": [
                            {
                                "identifier": "Url",
                                "columnName": "requestUri_s"
                            }
                        ]
                    },
                    {
                        "entityType": "Process",
                        "fieldMappings": [
                            {
                                "identifier": "ProcessId",
                                "columnName": "ruleName_s"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}