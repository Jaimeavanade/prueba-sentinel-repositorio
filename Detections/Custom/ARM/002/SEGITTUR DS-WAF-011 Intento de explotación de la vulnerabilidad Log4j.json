{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/310421c4-c8d1-4151-b842-38b5bc83fcdb')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/310421c4-c8d1-4151-b842-38b5bc83fcdb')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[SEGITTUR] DS-WAF-011 Intento de explotación de la vulnerabilidad Log4j",
                "description": "[SEGITTUR] DS-WAF-011 Intento de explotación de la vulnerabilidad Log4j en Azure WAF",
                "severity": "High",
                "enabled": true,
                "query": "let log4jioc = dynamic([\"jndi\",\"ldap\",\"${::\"]);\r\n  AzureDiagnostics\r\n  | where ResourceProvider == \"MICROSOFT.CDN\" and Category == \"FrontDoorWebApplicationFirewallLog\"\r\n  | extend matchVariableName_ = tostring(parse_json(details_matches_s)[0].matchVariableName)\r\n  | where requestUri_s has_any (log4jioc) or details_data_s has_any (log4jioc)\r\n  | extend matchVariableValue_ = tostring(parse_json(details_matches_s)[0].matchVariableValue)\r\n  | project TimeGenerated, matchVariableValue_, requestUri_s, action_s, ruleName_s, OperationName, SubscriptionId \r\n  | extend timestamp = TimeGenerated",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT5H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "IP"
                        ],
                        "groupByAlertDetails": [
                            "DisplayName"
                        ],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[SEGITTUR] DS-WAF-011 Intento de explotación de la vulnerabilidad Log4j desde {{matchVariableValue_}} ",
                    "alertDescriptionFormat": "[SEGITTUR] DS-WAF-011 Intento de explotación de la vulnerabilidad Log4j desde {{matchVariableValue_}} ",
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "matchVariableValue_"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}