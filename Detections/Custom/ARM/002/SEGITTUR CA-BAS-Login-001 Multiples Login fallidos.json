{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/c91b7696-c54d-4832-9bba-662caa645d65')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/c91b7696-c54d-4832-9bba-662caa645d65')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[SEGITTUR] CA-BAS-Login-001 Multiples Login fallidos",
                "description": "Detección de fuerza bruta de un usuario",
                "severity": "Low",
                "enabled": true,
                "query": "let threshold = 4; \r\nlet timeRange = 2h;\r\nMicrosoftAzureBastionAuditLogs\r\n| where OperationName == \"Microsoft.Network/BastionHost/disconnect\"\r\n| where Message == \"Login Failed\"\r\n| where TimeGenerated > ago(timeRange) // Filtra por los eventos ocurridos en los últimos 10 minutos\r\n| summarize Message=make_set(Message),startTime=min(TimeGenerated),endTime=max(TimeGenerated),EventCount = count() by UserName,UserEmail,TargetVMIPAddress \r\n| where EventCount>=threshold\r\n",
                "queryFrequency": "PT10M",
                "queryPeriod": "PT3H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "AlertPerResult"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[SEGITTUR] CA-BAS-Login-001 Multiples Login fallidos en {{TargetVMIPAddress}} con {{UserName}}",
                    "alertDescriptionFormat": "[SEGITTUR]CA-BAS-Login-001 Multiples Login fallidos en {{TargetVMIPAddress}} con {{UserName}}\nDatos UserMail: {{UserEmail}}\n",
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "UserName"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}