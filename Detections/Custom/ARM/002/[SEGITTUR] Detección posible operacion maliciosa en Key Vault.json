{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/a30ee796-7294-4bcc-ab61-caaa981d2afe')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/a30ee796-7294-4bcc-ab61-caaa981d2afe')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[SEGITTUR] Detección posible operacion maliciosa en Key Vault",
                "description": "[SEGITTUR] Detección posible operación maliciosa en Key Vault",
                "severity": "Medium",
                "enabled": true,
                "query": "let operationlist = dynamic(\n    [\"VaultDelete\", \"KeyDelete\", \"SecretDelete\", \"SecretPurge\", \"KeyPurge\", \"SecretBackup\", \"KeyBackup\", \"SecretListDeleted\", \"CertificateCreate\", \"CertificatePurge\"]);\nAzureDiagnostics\n| where ResourceType == \"VAULTS\" and ResultType == \"Success\"\n| where OperationName in (operationlist)\n| extend\n    JoinIP = tostring(split(CallerIPAddress, \":\")[0]),\n    User = coalesce(identity_claim_unique_name_s, identity_claim_upn_s)\n| where isnotempty(User)\n| join kind=leftouter (\n    DeviceNetworkInfo\n    | mv-expand IPAddresses\n    | extend JoinIP = tostring(IPAddresses.IPAddress)\n    | where isnotempty(JoinIP)\n    | project JoinIP, DeviceName\n    )\n    on JoinIP\n| project\n    TimeGenerated,\n    OperationName,\n    IpAddress=JoinIP,\n    User,\n    DeviceName,\n    KeyVaultName = Resource,\n    KeyVaultTarget = id_s,\n    ResourceGroup,\n    SubscriptionId\n\n",
                "queryFrequency": "PT5H",
                "queryPeriod": "PT5H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT8H",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account",
                            "IP"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "AlertPerResult"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "[SEGITTUR] Detección posible operación maliciosa en {{KeyVaultName}}  por {{User}} ",
                    "alertDescriptionFormat": "[SEGITTUR] Detección posible operación maliciosa {{OperationName}} en {{KeyVaultName}}  por {{User}} ",
                    "alertDynamicProperties": []
                },
                "customDetails": {},
                "entityMappings": [
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IpAddress"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "HostName",
                                "columnName": "SubscriptionId"
                            }
                        ]
                    },
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "User"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "ResourceGroup"
                            }
                        ]
                    },
                    {
                        "entityType": "Host",
                        "fieldMappings": [
                            {
                                "identifier": "AzureID",
                                "columnName": "SubscriptionId"
                            }
                        ]
                    },
                    {
                        "entityType": "Process",
                        "fieldMappings": [
                            {
                                "identifier": "ProcessId",
                                "columnName": "KeyVaultName"
                            }
                        ]
                    },
                    {
                        "entityType": "Process",
                        "fieldMappings": [
                            {
                                "identifier": "CommandLine",
                                "columnName": "KeyVaultTarget"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": [
                    {
                        "columnName": "OperationName"
                    }
                ],
                "templateVersion": null
            }
        }
    ]
}