{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/5816bc84-3294-4849-ac76-443802039214')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/5816bc84-3294-4849-ac76-443802039214')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "[GEN][MIN] AS-SNTL-041 Regla programada modificada o eliminada",
                "description": "Necesario excepcionar usuarios permitidos en watchlist. Este cdu detecta cuando se modifica o elimina una regla de Sentinel.",
                "severity": "Low",
                "enabled": true,
                "query": "let opValues = dynamic([\"Microsoft.SecurityInsights/alertRules/Write\", \"Microsoft.SecurityInsights/alertRules/Delete\"]);\r\n// Azure Sentinel Analytics - Rule Create / Delete\r\nlet watchlist_AS_SNTL_041_User = (_GetWatchlist('watchlist_AS_SNTL_041_User')\r\n| project SearchKey);\r\nSentinelAudit\r\n| where OperationName in (opValues)\r\n| sort by TimeGenerated desc\r\n| extend CallerName = tostring(ExtendedProperties.CallerName)\r\n| extend CallerIpAddress = tostring(ExtendedProperties.CallerIpAddress)\r\n| where CallerName !in (watchlist_AS_SNTL_041_User)\r\n| project TimeGenerated, ActorUsername = CallerName, SrcIpAddr = CallerIpAddress, Object = SentinelResourceName, ObjectType = SentinelResourceKind, Operation = OperationName, EventResultDetails = Status",
                "queryFrequency": "PT30M",
                "queryPeriod": "PT30M",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [],
                "techniques": [],
                "subTechniques": [],
                "alertRuleTemplateName": "5816bc84-3294-4849-ac76-443802039214",
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": true,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "P1D",
                        "matchingMethod": "Selected",
                        "groupByEntities": [
                            "Account"
                        ],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": {
                    "alertDisplayNameFormat": "AS-SNTL-041 Regla programada modificada o eliminada por {{ActorUsername}} ",
                    "alertDescriptionFormat": "Se detecta cambios en \"{{Object}}\" desde \"{{SrcIpAddr}}\" por {{ActorUsername}}.",
                    "alertDynamicProperties": []
                },
                "customDetails": null,
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "FullName",
                                "columnName": "ActorUsername"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "SrcIpAddr"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": [
                    {
                        "columnName": "Object"
                    }
                ],
                "templateVersion": "1.0.0"
            }
        }
    ]
}