{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspace": {
      "type": "string"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "apiVersion": "2023-02-01-preview",
      "kind": "Scheduled",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/Custom-TEST-WAF-001-T1594-Elevado-numero-de-peticiones-desde-el-mismo-origen-1E5F4FD6')]",
      "properties": {
        "displayName": "TEST WAF-001-T1594 Elevado número de peticiones  desde el mismo origen",
        "description": "",
        "severity": "Medium",
        "enabled": true,
        "query": "let Umbral = 1000;\nAzureDiagnostics\n| where httpMethod_s == \"GET\"\n| summarize Peticiones = count() by socketIp_s, requestUri_s\n| where Peticiones > Umbral",
        "queryFrequency": "PT5M",
        "queryPeriod": "PT5M",
        "triggerOperator": "GreaterThan",
        "triggerThreshold": 0,
        "suppressionEnabled": false
      }
    }
  ]
}
