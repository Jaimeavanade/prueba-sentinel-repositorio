{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "triggerOperator": {
      "defaultValue": "GreaterThan",
      "metadata": {
        "description": "Trigger operator."
      },
      "allowedValues": [
        "Equal",
        "GreaterThan",
        "LessThan",
        "NotEqual"
      ],
      "type": "string"
    },
    "tactics": {
      "defaultValue": [],
      "metadata": {
        "description": "The tactics of the alert rule"
      },
      "type": "array"
    },
    "workspaceName": {
      "defaultValue": "log-sentinel-segittur-015",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      },
      "type": "string"
    },
    "query": {
      "defaultValue": "",
      "metadata": {
        "description": "The query in KQL that creates alerts for this rule."
      },
      "type": "string"
    },
    "ruleId": {
      "defaultValue": "7a9e57b7-1251-c6e8-1694-5fca2fa2d30b",
      "metadata": {
        "description": "Stable GUID for this scheduled alert rule"
      },
      "type": "string"
    },
    "ruleDescription": {
      "defaultValue": "Identifies mass secret retrieval from Azure Key Vault observed by a single user. \nMass secret retrival crossing a certain threshold is an indication of credential dump operations or mis-configured applications. \nYou can tweak the EventCountThreshold based on average count seen in your environment \nand also filter any known sources (IP/Account) and useragent combinations based on historical analysis to further reduce noise",
      "metadata": {
        "description": "The description of the alert rule."
      },
      "type": "string"
    },
    "queryFrequency": {
      "defaultValue": "PT1H",
      "metadata": {
        "description": "The frequency (ISO 8601) for this alert rule to run. Example: PT1H"
      },
      "type": "string"
    },
    "severity": {
      "defaultValue": "Medium",
      "metadata": {
        "description": "The severity for alerts created by this alert rule."
      },
      "allowedValues": [
        "High",
        "Medium",
        "Low",
        "Informational"
      ],
      "type": "string"
    },
    "ruleDisplayName": {
      "defaultValue": "Mass secret retrieval from Azure Key Vault",
      "metadata": {
        "description": "Friendly name for the scheduled alert rule"
      },
      "type": "string"
    },
    "location": {
      "minLength": 1,
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Resource group to deploy solution resources"
      },
      "type": "string"
    },
    "suppressionDuration": {
      "defaultValue": "PT0H",
      "metadata": {
        "description": "Suppression duration (ISO 8601). Example: PT1H"
      },
      "type": "string"
    },
    "triggerThreshold": {
      "defaultValue": 0,
      "metadata": {
        "description": "Trigger threshold."
      },
      "type": "int"
    },
    "suppressionEnabled": {
      "defaultValue": false,
      "metadata": {
        "description": "Enable/disable suppression."
      },
      "type": "bool"
    },
    "queryPeriod": {
      "defaultValue": "PT1H",
      "metadata": {
        "description": "The lookback period (ISO 8601). Example: P2DT1H30M"
      },
      "type": "string"
    }
  },
  "functions": [],
  "variables": {},
  "resources": [
    {
      "kind": "Scheduled",
      "dependsOn": [],
      "location": "[parameters('location')]",
      "apiVersion": "2020-01-01",
      "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
      "name": "[concat(parameters('workspaceName'),'/Microsoft.SecurityInsights/',parameters('ruleId'))]",
      "properties": {
        "displayName": "[parameters('ruleDisplayName')]",
        "query": "[parameters('query')]",
        "enabled": true,
        "description": "[parameters('ruleDescription')]",
        "queryPeriod": "[parameters('queryPeriod')]",
        "suppressionEnabled": "[parameters('suppressionEnabled')]",
        "tactics": "[parameters('tactics')]",
        "queryFrequency": "[parameters('queryFrequency')]",
        "severity": "[parameters('severity')]",
        "triggerOperator": "[parameters('triggerOperator')]",
        "triggerThreshold": "[parameters('triggerThreshold')]",
        "suppressionDuration": "[parameters('suppressionDuration')]"
      }
    }
  ],
  "outputs": {
    "ruleId": {
      "type": "string",
      "value": "[parameters('ruleId')]"
    }
  }
}
